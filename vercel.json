{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,docs/**,.git/**,.pytest_cache/**,scripts/**,**/__pycache__/**,**/*.pyc}",
      "includeFiles": "config/settings.yml"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
